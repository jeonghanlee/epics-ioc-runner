#!/usr/bin/env bash
#
# A front-end CLI manager for EPICS IOCs.
# Utilizes systemd template units (@.service) for zero-dependency management.
# Supports both system-wide deployment and local user-level testing.
#
# Jeong Han Lee, Dr.rer.nat.
# jeonghan.lee@gmail.com
#

set -euo pipefail

# --- Version Information ---
declare -g RUNNER_VERSION="1.2.0-dev"
declare -g RUNNER_GIT_HASH="unknown"
declare -g RUNNER_COMMIT_DATE="unreleased"
declare -g RUNNER_INSTALL_DATE="unreleased"


# Defines global ANSI color codes for terminal output formatting.
declare -g RED='\033[0;31m'
declare -g GREEN='\033[0;32m'
declare -g BLUE='\033[0;34m'
# declare -g YELLOW='\033[0;33m'
declare -g NC='\033[0m'

# --- Configuration Directories ---
# Resolve HOME defensively: bare sudo or some systemd/cron contexts leave
# HOME unset, which would abort the LOCAL_* defaults below under 'set -u'
# (even for --help, -V, or system mode that never use them).
#
# HOME_TRUSTED records whether HOME is the user's real home (from the
# environment or the passwd database) or the world-writable '/tmp' fallback.
# The fallback is acceptable for the LOCAL_* directory defaults below, but a
# search for an executable (con / procServ) must not trust
# "${HOME}/.local/bin" when HOME resolved to '/tmp'; the home-bin search entry
# is gated on this flag.
declare -g HOME_TRUSTED=1
if [[ -z "${HOME:-}" ]]; then
    HOME="$(getent passwd "$(id -un)" 2>/dev/null | cut -d: -f6 || true)"
    if [[ -z "${HOME}" ]]; then
        HOME="/tmp"
        HOME_TRUSTED=0
    fi
fi
declare -g SYSTEM_CONF_DIR="${IOC_RUNNER_SYSTEM_CONF_DIR:-/etc/procServ.d}"
declare -g LOCAL_CONF_DIR="${IOC_RUNNER_LOCAL_CONF_DIR:-${HOME}/.config/procServ.d}"
declare -g SYSTEM_SYSTEMD_DIR="${IOC_RUNNER_SYSTEM_SYSTEMD_DIR:-/etc/systemd/system}"
declare -g LOCAL_SYSTEMD_DIR="${IOC_RUNNER_LOCAL_SYSTEMD_DIR:-${HOME}/.config/systemd/user}"
declare -g SYSTEM_RUN_DIR="${IOC_RUNNER_SYSTEM_RUN_DIR:-/run/procserv}"
declare -g LOCAL_RUN_DIR="${IOC_RUNNER_LOCAL_RUN_DIR:-/run/user/$(id -u)/procserv}"
declare -g SYSTEM_LOG_DIR="${IOC_RUNNER_SYSTEM_LOG_DIR:-/var/log/procserv}"
declare -g LOCAL_LOG_DIR="${IOC_RUNNER_LOCAL_LOG_DIR:-${XDG_STATE_HOME:-${HOME}/.local/state}/procserv}"

# --- Base Commands & Paths ---
declare -g SYSTEMCTL_BIN="/usr/bin/systemctl"

if [[ ! -x "${SYSTEMCTL_BIN}" ]]; then
    printf "Error: %s not found or not executable. This script requires systemd.\n" "${SYSTEMCTL_BIN}" >&2
    exit 1
fi

declare -g -a CON_SEARCH_PATHS=("/usr/local/bin/con" "/usr/bin/con")
declare -g -a PROCSERV_SEARCH_PATHS=("/usr/local/bin/procServ" "/usr/bin/procServ")

# Prepend the per-user home-bin location so a user-built con / procServ in
# "${HOME}/.local/bin" is found first (resolution order: home -> /usr/local ->
# /usr). Gated on HOME_TRUSTED: a '/tmp' fallback HOME is world-writable and
# must not be a trusted source of executables.
if [[ "${HOME_TRUSTED}" -eq 1 ]]; then
    CON_SEARCH_PATHS=("${HOME}/.local/bin/con" "${CON_SEARCH_PATHS[@]}")
    PROCSERV_SEARCH_PATHS=("${HOME}/.local/bin/procServ" "${PROCSERV_SEARCH_PATHS[@]}")
fi

declare -g EXEC_MODE="system"
declare -g CONF_DIR="${IOC_RUNNER_CONF_DIR:-${SYSTEM_CONF_DIR}}"
declare -g SYSTEMD_DIR="${IOC_RUNNER_SYSTEMD_DIR:-${SYSTEM_SYSTEMD_DIR}}"
declare -g RUN_DIR="${IOC_RUNNER_RUN_DIR:-${SYSTEM_RUN_DIR}}"
declare -g LOG_DIR="${IOC_RUNNER_LOG_DIR:-${SYSTEM_LOG_DIR}}"

declare -g VERBOSE_LEVEL=0
declare -g FORCE_OVERWRITE=0

# --- Target Identity Settings ---
declare -g TARGET_SYSTEM_USER="ioc-srv"
declare -g TARGET_SYSTEM_GROUP="ioc"

# --- Health Check Configuration ---
# Regex pattern used to detect fatal errors or crash-loops in procServ logs immediately after startup.
# Users can add custom error strings specific to their hardware or EPICS modules here (separated by '|').
declare -g CRASH_LOG_PATTERNS="(error while loading|FATAL|Segmentation fault|ERROR|Unbalanced quote|Invalid directory path|Can't open|cannot open|undefined symbol|No such file or directory)"
# Benign startup lines removed from the scan input before pattern matching (issue #92).
# The iocsh history load/save failure is emitted with ANSI escapes around 'ERROR'
# (EPICS Base iocsh.cpp via ERL_ERROR), so the regex anchors on the escape-free message
# tail and must not span the escape boundary or anchor on end-of-line (pty may add CR).
# Case-sensitive by design; not user-extensible (an over-broad exclusion would silently
# disable crash detection).
declare -g CRASH_LOG_EXCLUDE_PATTERNS="Permission denied \([0-9]+\) (loading|writing) '[^']*iocsh_history'"


function print_divider {
    printf "%s\n" "===================================================================================================="
}

function print_sub_divider {
    printf "%s\n" "----------------------------------------------------------------------------------------------------"
}

function set_local_mode {
    EXEC_MODE="local"
    CONF_DIR="${IOC_RUNNER_CONF_DIR:-${LOCAL_CONF_DIR}}"
    SYSTEMD_DIR="${IOC_RUNNER_SYSTEMD_DIR:-${LOCAL_SYSTEMD_DIR}}"
    RUN_DIR="${IOC_RUNNER_RUN_DIR:-${LOCAL_RUN_DIR}}"
    LOG_DIR="${IOC_RUNNER_LOG_DIR:-${LOCAL_LOG_DIR}}"
}

function print_usage {
    local prog_name
    prog_name=$(basename "$0")

    cat << EOF
EPICS IOC Runner - CLI Manager

Usage: ${prog_name} [OPTIONS] COMMAND [TARGET]

Options:
  --local        Run in local user mode (no sudo required, uses ~/.config/procServ.d). Alias: --user
  -f, --force    Force overwrite of existing configuration files without prompting
  -v, -vv        Verbose output (supported only for 'list' command)
  -V, --version  Show version, git hash, commit date, and install date
  -h, --help     Show this help message and exit

Commands:
  generate       Auto-generate and validate a .conf file from an iocBoot directory
  install        Install a new IOC configuration file (.conf) and reload systemd
  remove         Stop, disable, and remove an existing IOC configuration
  start          Start the specified IOC service
  stop           Stop the specified IOC service
  restart        Restart the specified IOC service
  status         Show the systemd status of the IOC service
  enable         Enable the IOC service to start on boot
  disable        Disable the IOC service from starting on boot
  view           Print the IOC configuration file and the rendered systemd unit
  list           List all active IOC sockets
                   (default: name, status, start time, path)
                   (-v: adds PID, CPU, memory)
                   (-vv: adds Recv-Q, Send-Q, kernel state, inode, permissions)
  attach         Attach to the IOC console via UNIX Domain Socket (read/write)
  monitor        Attach to the IOC console in read-only mode (prevents input interleaving)
  inspect        Deep trace of socket file descriptors and client PIDs (sudo in system mode)

Examples:
  ${prog_name} generate /path/to/iocBoot # Auto-generate myioc.conf in current directory
  ${prog_name} install myioc.conf        # Install system-wide IOC
  ${prog_name} start myioc               # Start the system-wide IOC
  ${prog_name} attach myioc              # Connect to the IOC console (read/write)
  ${prog_name} monitor myioc             # Connect to the IOC console (read-only)
  sudo ${prog_name} inspect myioc        # Trace active clients on the IOC socket
  ${prog_name} --local install t.conf    # Install IOC in local user space
  ${prog_name} list                      # List all IOCs with basic info
  ${prog_name} list -v                   # List with PID, CPU, memory
  ${prog_name} list -vv                  # List with full kernel and socket details
  ${prog_name} --local list -v           # Local mode with verbose output
EOF
}

function validate_ioc_name {
    local name="$1"
    local context="${2:-}"
    local LC_ALL=C   # locale-independent character-class matching

    if [[ "${#name}" -le 64 && "${name}" =~ ^[a-zA-Z0-9_][a-zA-Z0-9_-]*$ ]]; then
        return 0
    fi

    if [[ -n "${context}" ]]; then
        printf "Error: Invalid IOC name '%s' %s. Only alphanumeric characters, '-', and '_' are allowed; must not start with '-', max 64 chars.\n" "${name}" "${context}" >&2
    else
        printf "Error: Invalid IOC name '%s'. Only alphanumeric characters, '-', and '_' are allowed; must not start with '-', max 64 chars.\n" "${name}" >&2
    fi
    return 1
}

# --- CLI Argument Parsing ---
declare -g COMMAND_ACTION=""
declare -g TARGET_ARG=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --local|--user)
            set_local_mode
            ;;
        -f|--force)
            FORCE_OVERWRITE=1
            ;;
        -vv)
            VERBOSE_LEVEL=2
            ;;
        -v)
            VERBOSE_LEVEL=1
            ;;
        -V|--version)
            display_hash="${RUNNER_GIT_HASH}"
            display_commit_date="${RUNNER_COMMIT_DATE}"
            display_install_date="${RUNNER_INSTALL_DATE}"
            if [[ "${display_hash}" == "unknown" ]]; then
                script_dir="$(dirname "${BASH_SOURCE[0]}")"
                if command -v git >/dev/null 2>&1 && git -C "${script_dir}" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
                    display_hash=$(git -C "${script_dir}" rev-parse --short HEAD)
                    if ! git -C "${script_dir}" diff-index --quiet HEAD -- 2>/dev/null; then
                        display_hash="${display_hash}-dirty"
                    fi
                    display_hash="${display_hash} (live)"
                    commit_ts=$(git -C "${script_dir}" show -s --format=%ct HEAD 2>/dev/null || printf "")
                    if [[ -n "${commit_ts}" ]]; then
                        display_commit_date=$(date -u -d "@${commit_ts}" +"%Y-%m-%dT%H:%M:%SZ")
                    else
                        display_commit_date="unknown"
                    fi
                    display_install_date="live"
                fi
            fi
            printf "epics-ioc-runner version %s (%s)\n" "${RUNNER_VERSION}" "${display_hash}"
            printf "commit date:  %s\n" "${display_commit_date}"
            printf "install date: %s\n" "${display_install_date}"
            exit 0
            ;;
        -h|--help)
            print_usage
            exit 0
            ;;
        -*)
            printf "Error: Unknown option '%s'\n" "$1" >&2
            print_usage
            exit 1
            ;;
        *)
            # The first non-option argument is the command, the second is the target
            if [[ -z "${COMMAND_ACTION}" ]]; then
                COMMAND_ACTION="$1"
            elif [[ -z "${TARGET_ARG}" ]]; then
                TARGET_ARG="$1"
            else
                printf "Error: Unexpected argument '%s'\n" "$1" >&2
                print_usage
                exit 1
            fi
            ;;
    esac
    shift
done

if [[ -z "${COMMAND_ACTION}" ]]; then
    print_usage
    exit 0
fi

# Hard guard: the system-mode socket path comes from RUN_DIR, but the
# system-mode systemd template hardcodes RuntimeDirectory=procserv/%i
# (resolves under /run/procserv). Either IOC_RUNNER_RUN_DIR or
# IOC_RUNNER_SYSTEM_RUN_DIR can move RUN_DIR off /run/procserv, splitting the
# declared socket path from where the kernel creates the UDS -- breaking
# list/attach/remove/inspect (and pointing do_remove's rm -rf at a path the
# operator never intended). Checking resolved RUN_DIR catches both overrides.
# Rejected outright in system mode; --local is the supported path.
if [[ "${EXEC_MODE}" == "system" && "${RUN_DIR}" != "/run/procserv" ]]; then
    printf "Error: system-mode runtime dir (%s) diverges from the fixed systemd\n" "${RUN_DIR}" >&2
    printf "       RuntimeDirectory (/run/procserv); the socket path and the runner\n" >&2
    printf "       would split, breaking list/attach/remove/inspect.\n" >&2
    printf "       Unset IOC_RUNNER_RUN_DIR / IOC_RUNNER_SYSTEM_RUN_DIR, or use --local.\n" >&2
    exit 1
fi

# Foot-gun guard: IOC_RUNNER_LOG_DIR shifts where the runner scans for crash
# patterns; the scan path (LOG_DIR) must match where procServ actually writes.
# - system mode: procServ writes to SYSTEM_LOG_DIR (fixed by the system
#   template), so an IOC_RUNNER_LOG_DIR override that differs guarantees a
#   mismatch.
# - local mode: the user unit bakes the resolved LOG_DIR as --logfile at
#   install time, so a different IOC_RUNNER_LOG_DIR or IOC_RUNNER_LOCAL_LOG_DIR
#   at start/restart scans a file procServ is not writing to.
if [[ "${EXEC_MODE}" == "system" && -n "${IOC_RUNNER_LOG_DIR:-}" \
      && "${IOC_RUNNER_LOG_DIR}" != "${SYSTEM_LOG_DIR}" ]]; then
    printf "Warning: IOC_RUNNER_LOG_DIR (%s) differs from SYSTEM_LOG_DIR (%s).\n" \
           "${IOC_RUNNER_LOG_DIR}" "${SYSTEM_LOG_DIR}" >&2
    printf "         The runner will scan the override path, but procServ writes to\n" >&2
    printf "         SYSTEM_LOG_DIR per the system systemd template. Use --local for\n" >&2
    printf "         custom paths.\n" >&2
elif [[ "${EXEC_MODE}" == "local" && ( -n "${IOC_RUNNER_LOG_DIR:-}" || -n "${IOC_RUNNER_LOCAL_LOG_DIR:-}" ) ]]; then
    printf "Warning: the local log directory (%s), set via IOC_RUNNER_LOG_DIR or\n" "${LOG_DIR}" >&2
    printf "         IOC_RUNNER_LOCAL_LOG_DIR, is baked into the user unit's --logfile\n" >&2
    printf "         at install time. Export the same value when you start or restart\n" >&2
    printf "         the IOC, or the crash scan reads a path procServ is not writing to.\n" >&2
fi

# Strict validation for command-specific flags
if [[ ${VERBOSE_LEVEL} -gt 0 && "${COMMAND_ACTION}" != "list" ]]; then
    printf "Error: Verbose options (-v, -vv) are only supported for the 'list' command.\n" >&2
    exit 1
fi

declare -g IOC_NAME=""

if [[ -n "${TARGET_ARG}" ]]; then
    IOC_NAME=$(basename "${TARGET_ARG}" .conf)

    # Defers strict regex validation for commands that accept relative paths or directories.
    if [[ "${COMMAND_ACTION}" != "generate" && "${COMMAND_ACTION}" != "install" ]]; then
        validate_ioc_name "${IOC_NAME}" || exit 1
    fi
fi


function run_systemctl {
    local action="$1"
    shift

    if [[ "${EXEC_MODE}" == "local" ]]; then
        "${SYSTEMCTL_BIN}" --user "${action}" "$@"
    else
        case "${action}" in
            is-active|status|cat|show)
                "${SYSTEMCTL_BIN}" "${action}" "$@"
                ;;
            *)
                if [[ $EUID -eq 0 ]]; then
                    "${SYSTEMCTL_BIN}" "${action}" "$@"
                else
                    sudo "${SYSTEMCTL_BIN}" "${action}" "$@"
                fi
                ;;
        esac
    fi
}

function deploy_local_template {
    local template_path="${SYSTEMD_DIR}/epics-@.service"
    local backup_path=""

    resolve_procserv_tool
    local procserv_bin="${PROCSERV_TOOL_PATH}"

    mkdir -p "${SYSTEMD_DIR}"

    # Always emit the template. Back up any prior file atomically via
    # mktemp so repeated installs in the same second do not collide,
    # including on shared (NFS-backed) home directories. mktemp creates
    # an empty placeholder at a unique path; the subsequent mv -f swaps
    # in the prior template.
    if [[ -f "${template_path}" ]]; then
        if ! backup_path=$(mktemp "${template_path}.bak.XXXXXXXX" 2>/dev/null); then
            printf "Error: Unable to create backup of existing user template.\n" >&2
            printf "  template: %s\n" "${template_path}" >&2
            printf "  Possible causes: %s is read-only, the home directory is\n" "${SYSTEMD_DIR}" >&2
            printf "    full, or the filesystem does not allow file creation here.\n" >&2
            printf "  Resolve the underlying condition and re-run 'ioc-runner --local install'.\n" >&2
            exit 1
        fi
        mv -f "${template_path}" "${backup_path}"
        printf "Backed up existing user template to %s\n" "${backup_path}"
        # Prune old template backups, keeping the 3 most recent.
        local -a old_backups=()
        mapfile -t old_backups < <(ls -1t "${template_path}".bak.* 2>/dev/null)
        if (( ${#old_backups[@]} > 3 )); then
            rm -f -- "${old_backups[@]:3}"
        fi
    fi

    printf "Deploying user-level systemd template to %s...\n" "${template_path}"
    cat > "${template_path}" <<EOF
[Unit]
Description=procServ for %i (Local User)
AssertFileNotEmpty=${CONF_DIR}/%i.conf

[Service]
Type=simple
UMask=0027
EnvironmentFile=${CONF_DIR}/%i.conf
RuntimeDirectory=procserv/%i
RuntimeDirectoryMode=0770
ExecStart=${procserv_bin} --foreground --logfile=${LOG_DIR}/%i.log --name=%i --ignore=^D^C^] --chdir=\${IOC_CHDIR} --port=\${IOC_PORT} \${IOC_CMD}
SuccessExitStatus=0 1 2 15 143 SIGTERM SIGKILL
StandardOutput=journal
StandardError=inherit
SyslogIdentifier=epics-%i

[Install]
WantedBy=default.target
EOF
    run_systemctl daemon-reload
}

# Parse a specific key from a configuration file using only bash built-ins
function read_conf_var {
    local conf_file="$1"
    local target_key="$2"
    local key
    local val

    while IFS='=' read -r key val || [[ -n "${key:-}" ]]; do
        key="${key// /}"
        if [[ -z "${key}" || "${key}" =~ ^# || "${key}" != "${target_key}" ]]; then
            continue
        fi
        val="${val%\"}"; val="${val#\"}"
        val="${val%\'}"; val="${val#\'}"
        # Strip carriage returns to prevent path errors from files edited on Windows
        val="${val%$'\r'}"

        printf "%s" "${val}"
        return 0
    done < "${conf_file}"
    return 1
}

function read_conf_all {
    local conf_file="$1"
    local -n result_map="$2"

    local key val
    while IFS='=' read -r key val || [[ -n "${key:-}" ]]; do
        key="${key// /}"
        [[ -z "${key}" || "${key}" =~ ^# ]] && continue
        val="${val#"${val%%[![:space:]]*}"}"   # trim leading whitespace
        val="${val%"${val##*[![:space:]]}"}"   # trim trailing whitespace
        val="${val%\"}"; val="${val#\"}"
        val="${val%\'}"; val="${val#\'}"
        val="${val%$'\r'}"
        # shellcheck disable=SC2034
        result_map["${key}"]="${val}"
    done < "${conf_file}"
}

function get_file_size {
    local path="$1"
    local size="0"

    if [[ -f "${path}" ]]; then
        size=$(stat -c '%s' "${path}" 2>/dev/null || printf "0")
        if [[ ! "${size}" =~ ^[0-9]+$ ]]; then
            size="0"
        fi
    fi

    printf "%s" "${size}"
}

# Capture the file's inode for rotation detection. Empty on missing/
# unreadable file or stat failure so the caller can detect-and-skip
# instead of misinterpreting an empty value as a changed inode.
function get_file_inode {
    local path="$1"
    local inode=""

    if [[ -f "${path}" ]]; then
        inode=$(stat -c '%i' "${path}" 2>/dev/null || printf "")
        if [[ ! "${inode}" =~ ^[0-9]+$ ]]; then
            inode=""
        fi
    fi

    printf "%s" "${inode}"
}

# Hash the last 64 bytes ending at end_offset. Used as a fingerprint to
# detect same-inode truncate-and-regrow-past-old-offset rotations that
# inode and size guards alone cannot distinguish. Empty hash on
# unreadable file, zero/negative offset, or any tool failure so the
# scanner skips the comparison rather than treating it as a mismatch.
function get_file_tailhash {
    local path="$1"
    local end_offset="$2"
    local start n hash

    if [[ ! -r "${path}" || "${end_offset}" -le 0 ]]; then
        printf ""
        return
    fi

    n=64
    if [[ "${end_offset}" -lt "${n}" ]]; then
        n="${end_offset}"
    fi
    start=$((end_offset - n))

    if ! hash=$(dd if="${path}" bs=1 count="${n}" skip="${start}" \
                  iflag=skip_bytes,count_bytes status=none 2>/dev/null \
                  | sha256sum 2>/dev/null | cut -d' ' -f1); then
        hash=""
    fi

    printf "%s" "${hash}"
}

function scan_file_for_crash_patterns {
    local log_file="$1"
    local start_offset="$2"
    local start_inode="$3"
    local start_tailhash="$4"
    local patterns="$5"
    local current_size current_inode current_tailhash
    local scan_offset

    if [[ ! -r "${log_file}" ]]; then
        return 2
    fi

    current_size=$(get_file_size "${log_file}")
    current_inode=$(get_file_inode "${log_file}")
    scan_offset="${start_offset}"

    # Rotation/truncation detection, in precedence order:
    # 1. Inode changed -> file was replaced (rename-style rotation or
    #    "file appeared after capture"); scan from 0.
    # 2. Current size below captured size -> truncated in place
    #    (copytruncate path while regrowth has not passed the old
    #    offset); scan from 0.
    # 3. Same inode, size >= captured offset, but the byte window
    #    ending at the captured offset no longer matches its
    #    capture-time fingerprint -> copytruncate-then-regrow-past;
    #    scan from 0.
    if [[ -n "${start_inode}" && -n "${current_inode}" && "${current_inode}" != "${start_inode}" ]]; then
        scan_offset=0
    elif [[ "${current_size}" -lt "${scan_offset}" ]]; then
        scan_offset=0
    elif [[ -n "${start_tailhash}" ]]; then
        current_tailhash=$(get_file_tailhash "${log_file}" "${start_offset}")
        if [[ -n "${current_tailhash}" && "${current_tailhash}" != "${start_tailhash}" ]]; then
            scan_offset=0
        fi
    fi

    # Issue #92: line-targeted benign-noise pre-filter. The empty-value guard is
    # mandatory: 'grep -v ""' removes every line and would blank the scan entirely.
    if [[ -n "${CRASH_LOG_EXCLUDE_PATTERNS}" ]]; then
        if tail -c "+$((scan_offset + 1))" "${log_file}" 2>/dev/null | grep -vE "${CRASH_LOG_EXCLUDE_PATTERNS}" | grep -qiE "${patterns}"; then
            return 0
        fi
        return 1
    fi

    if tail -c "+$((scan_offset + 1))" "${log_file}" 2>/dev/null | grep -qiE "${patterns}"; then
        return 0
    fi

    return 1
}

function print_log_file_hint {
    local log_file="$1"

    printf "  -> Check logs: tail -f %s\n" "${log_file}" >&2
}

# Generate or correct the UNIX domain socket path based on the execution mode
function process_ioc_port {
    local ioc_name="$1"
    local input_port="$2"
    local target_user target_group run_base_dir

    if [[ "${EXEC_MODE}" == "system" ]]; then
        target_user="${TARGET_SYSTEM_USER}"
        target_group="${TARGET_SYSTEM_GROUP}"
    else
        target_user=$(id -un)
        target_group=$(id -gn)
    fi
    run_base_dir="${RUN_DIR}"

    local std_path="${run_base_dir}/${ioc_name}/control"
    local std_port="unix:${target_user}:${target_group}:0660:${std_path}"

    if [[ -z "${input_port}" ]]; then
        printf "%s" "${std_port}"
    elif [[ "${EXEC_MODE}" == "system" ]]; then
        if [[ "${input_port}" != "${std_port}" ]]; then
            printf "Error: IOC_PORT mismatch. Expected: %s\n" "${std_port}" >&2
            return 1
        fi
        printf "%s" "${input_port}"
    else
        printf "%s" "${std_port}"
    fi
}


# Validate the configuration file strictly before any deployment actions
function validate_conf {
    local conf_file="$1"
    local -n conf_vars="$2"    # nameref to caller's map
    local error_count=0
    local current_user current_group exec_bin

    printf "Validating configuration file: %s...\n" "${conf_file}"

    if ! bash -n "${conf_file}" 2>/dev/null; then
        printf "Error: Syntax error detected in %s\n" "${conf_file}" >&2
        return 1
    fi

    read_conf_all "${conf_file}" conf_vars

    # Required keys must be present and non-empty. The empty-string check
    # below intentionally conflates missing key and empty value: both
    # states are invalid for required keys (not a regression of #36's
    # read_conf_var distinction, which still applies to callers that
    # need to tell the two apart).
    local required_key
    for required_key in "IOC_USER" "IOC_GROUP" "IOC_CHDIR" "IOC_CMD"; do
        if [[ -z "${conf_vars[${required_key}]:-}" ]]; then
            printf "Error: Required variable %s is missing or empty.\n" "${required_key}" >&2
            error_count=$((error_count + 1))
        fi
    done

    # Whitelist security checks for critical variables
    local key val
    for key in "IOC_USER" "IOC_GROUP" "IOC_CHDIR" "IOC_PORT" "IOC_CMD"; do
        val="${conf_vars[${key}]:-}"
        if [[ -n "${val}" && ! "${val}" =~ ^[a-zA-Z0-9_./:\ -]+$ ]]; then
            printf "Error: Illegal characters detected in variable %s\n" "${key}" >&2
            error_count=$((error_count + 1))
        fi
    done

    # Optional CRASH_LOG_PATTERNS_EXTRA: per-IOC pattern extension validated
    # with a wider whitelist (regex metacharacters | ( ) \ allowed) and a
    # grep -E compile probe to catch invalid regex at install time.
    local extra_patterns="${conf_vars[CRASH_LOG_PATTERNS_EXTRA]:-}"
    if [[ -n "${extra_patterns}" ]]; then
        local extra_re='^[a-zA-Z0-9_./: |()\\-]+$'
        if [[ ! "${extra_patterns}" =~ ${extra_re} ]]; then
            printf "Error: Illegal characters in CRASH_LOG_PATTERNS_EXTRA.\n" >&2
            error_count=$((error_count + 1))
        else
            local grep_rc=0
            printf "" | grep -qE "${extra_patterns}" 2>/dev/null || grep_rc=$?
            if [[ ${grep_rc} -eq 2 ]]; then
                printf "Error: Invalid regex syntax in CRASH_LOG_PATTERNS_EXTRA.\n" >&2
                error_count=$((error_count + 1))
            fi
        fi
    fi

    # Identity validation checks
    if [[ "${EXEC_MODE}" == "system" ]]; then
        if [[ "${conf_vars[IOC_USER]:-}" != "${TARGET_SYSTEM_USER}" ]]; then
            printf "Error: System IOCs must run as %s\n" "${TARGET_SYSTEM_USER}" >&2
            error_count=$((error_count + 1))
        fi
        if [[ "${conf_vars[IOC_GROUP]:-}" != "${TARGET_SYSTEM_GROUP}" ]]; then
            printf "Error: System IOCs must run under group %s\n" "${TARGET_SYSTEM_GROUP}" >&2
            error_count=$((error_count + 1))
        fi
    else
        current_user=$(id -un)
        current_group=$(id -gn)

        if [[ "${conf_vars[IOC_USER]:-}" != "${current_user}" ]]; then
            printf "Error: Local IOCs must run as %s\n" "${current_user}" >&2
            error_count=$((error_count + 1))
        fi
        if [[ "${conf_vars[IOC_GROUP]:-}" != "${current_group}" ]]; then
            printf "Error: Local IOCs must run under group %s\n" "${current_group}" >&2
            error_count=$((error_count + 1))
        fi
    fi

    # Path and execution permission validation checks
    local chdir="${conf_vars[IOC_CHDIR]:-}"
    local cmd="${conf_vars[IOC_CMD]:-}"

    if [[ -z "${chdir}" || ! -d "${chdir}" ]]; then
        printf "Error: Invalid or missing directory: %s\n" "${chdir}" >&2
        error_count=$((error_count + 1))
    elif [[ ! -x "${chdir}" ]]; then
        printf "Error: Execute permission denied for directory: %s\n" "${chdir}" >&2
        error_count=$((error_count + 1))
    else
        if [[ -n "${cmd}" ]]; then
            read -r exec_bin _ <<< "${cmd}"

            # Verify if the binary is executable in the target directory or available in the system PATH
            if [[ ! -x "${chdir}/${exec_bin}" ]] && ! command -v "${exec_bin}" >/dev/null 2>&1; then
                printf "Error: Command not executable or not found: %s\n" "${exec_bin}" >&2
                printf "  Hint: Did you forget 'chmod +x %s'?\n" "${exec_bin}" >&2
                printf "  Hint: Is it a valid system command in your PATH?\n" >&2
                error_count=$((error_count + 1))
            fi
        fi
    fi

    if [[ ${error_count} -ne 0 ]]; then
        printf "Validation failed with %d errors. Installation aborted.\n" "${error_count}" >&2
        return 1
    fi

    printf "%s\n" "Validation passed successfully."
    return 0
}

# --- Shared Console Tool Resolution ---
declare -g CON_TOOL_PATH=""
declare -g CON_TOOL_TYPE=""

function resolve_con_tool {
    CON_TOOL_PATH="${IOC_RUNNER_CON_TOOL:-}"
    CON_TOOL_TYPE=""

    if [[ -z "${CON_TOOL_PATH}" ]]; then
        for path in "${CON_SEARCH_PATHS[@]}"; do
            if [[ -x "${path}" ]]; then
                CON_TOOL_PATH="${path}"
                CON_TOOL_TYPE="con"
                return 0
            fi
        done
    else
        if [[ ! -f "${CON_TOOL_PATH}" || ! -x "${CON_TOOL_PATH}" ]]; then
            printf "Error: IOC_RUNNER_CON_TOOL '%s' is not an executable file.\n" "${CON_TOOL_PATH}" >&2
            exit 1
        fi
        CON_TOOL_TYPE="con"
        return 0
    fi

    if command -v socat >/dev/null 2>&1; then
        CON_TOOL_PATH="socat"
        CON_TOOL_TYPE="socat"
        return 0
    fi

    if command -v nc >/dev/null 2>&1; then
        if nc -h 2>&1 | grep -q "\-U"; then
            CON_TOOL_PATH="nc"
            CON_TOOL_TYPE="nc"
            return 0
        fi
    fi

    printf "Error: No suitable tool (con, socat, nc) found for console attachment.\n" >&2
    printf "Recommendation: Install 'con' for the best experience (supports Ctrl-A to detach).\n" >&2
    printf "Source: https://github.com/jeonghanlee/con\n" >&2
    exit 1
}

# --- procServ Tool Resolution ---
# Mirrors resolve_con_tool: IOC_RUNNER_PROCSERV_TOOL takes precedence over the
# PROCSERV_SEARCH_PATHS default search list. procServ has no client-side
# fallback (unlike con's socat/nc), so a failed search is a hard error. The
# '-f && -x' override check matches the IOC_RUNNER_CON_TOOL semantics (a regular
# executable file, so an executable directory is rejected). Sets
# PROCSERV_TOOL_PATH on success; exits non-zero otherwise.
declare -g PROCSERV_TOOL_PATH=""

function resolve_procserv_tool {
    PROCSERV_TOOL_PATH="${IOC_RUNNER_PROCSERV_TOOL:-}"

    if [[ -z "${PROCSERV_TOOL_PATH}" ]]; then
        for path in "${PROCSERV_SEARCH_PATHS[@]}"; do
            if [[ -x "${path}" ]]; then
                PROCSERV_TOOL_PATH="${path}"
                return 0
            fi
        done
    else
        if [[ ! -f "${PROCSERV_TOOL_PATH}" || ! -x "${PROCSERV_TOOL_PATH}" ]]; then
            printf "Error: IOC_RUNNER_PROCSERV_TOOL '%s' is not an executable file.\n" "${PROCSERV_TOOL_PATH}" >&2
            exit 1
        fi
        return 0
    fi

    printf "%s\n" "Error: procServ executable not found in standard paths." >&2
    exit 1
}

# Resolve and validate the UDS socket path for an IOC.
# Sets RESOLVED_SOCK_PATH on success.
declare -g RESOLVED_SOCK_PATH=""

function resolve_sock_path {
    if [[ -z "${IOC_NAME}" ]]; then
        printf "Error: Target IOC name is required.\n" >&2
        exit 1
    fi

    local target_conf="${CONF_DIR}/${IOC_NAME}.conf"
    if [[ ! -f "${target_conf}" ]]; then
        printf "Error: Configuration for %s not found.\n" "${IOC_NAME}" >&2
        exit 1
    fi

    local state
    state=$(run_systemctl is-active "epics-@${IOC_NAME}.service" 2>/dev/null || true)
    if [[ "${state}" != "active" ]]; then
        print_divider >&2
        printf "WARNING: Service 'epics-@%s.service' is currently '%s'.\n" "${IOC_NAME}" "${state}" >&2
        printf "The socket file may be stale. The console connection might fail or hang.\n" >&2
        print_divider >&2
    fi

    local ioc_port_val
    if ! ioc_port_val=$(read_conf_var "${target_conf}" "IOC_PORT"); then
        printf "Error: IOC_PORT not configured in %s.\n" "${target_conf}" >&2
        exit 1
    fi
    RESOLVED_SOCK_PATH="${ioc_port_val##*:}"

    if [[ -z "${RESOLVED_SOCK_PATH}" || ! -S "${RESOLVED_SOCK_PATH}" ]]; then
        printf "Error: Socket file not found or invalid: %s\n" "${RESOLVED_SOCK_PATH}" >&2
        exit 1
    fi
}

# Analyzes an EPICS iocBoot directory, dynamically generates a compliant procServ configuration file,
# validates its parameters, and outputs the result to the current working directory for review.
# Eliminates subshell forks by utilizing native Bash parameter expansion and built-in directory traversal.
# Provides a unified diff preview if the target configuration file already exists before overwriting.
function do_generate {
    local target_dir="${TARGET_ARG}"
    local generated_conf=""
    local tmp_conf=""
    local confirm=""
    local abs_dir=""
    local saved_pwd=""
    local cmd_file=""
    local ioc_user=""
    local ioc_group=""
    local f=""
    local i=0
    local selection=""
    local -a cmd_candidates=()
    # shellcheck disable=SC2034
    local -A validate_map=()
    local mode_flag=""
    local line=""

    if [[ ! -d "${target_dir}" ]]; then
        printf "Error: Target '%s' is not a valid directory.\n" "${target_dir}" >&2
        exit 1
    fi

    # Resolves absolute path natively via Bash built-ins to avoid subshell forks and external binaries.
    saved_pwd="${PWD}"
    cd "${target_dir}" >/dev/null 2>&1 || exit 1
    abs_dir="${PWD}"
    cd "${saved_pwd}" >/dev/null 2>&1 || exit 1

    # Extracts the base name from the absolute path if the target is unspecified or passed as a relative dot.
    if [[ -z "${IOC_NAME}" || "${IOC_NAME}" == "${target_dir}" || "${IOC_NAME}" == "." ]]; then
        IOC_NAME="${abs_dir##*/}"
    fi

    # Enforces naming constraints strictly after native path expansion.
    validate_ioc_name "${IOC_NAME}" "derived from path" || exit 1

    # Saves the generated configuration directly in the target iocBoot directory alongside the startup script.
    generated_conf="${abs_dir}/${IOC_NAME}.conf"

    # Scans the target directory for executable .cmd files.
    # Automatically assigns the script if unique, aborts if missing, and provides an interactive
    # selection prompt for multiple candidates. Respects the CI/CD bypass flag to prevent pipeline hangs.
    for f in "${abs_dir}"/*.cmd; do
        if [[ -f "${f}" && -x "${f}" ]]; then
            cmd_candidates+=("${f##*/}")
        fi
    done

    if [[ ${#cmd_candidates[@]} -eq 0 ]]; then
        printf "Error: Could not resolve any executable .cmd file in %s\n" "${abs_dir}" >&2
        exit 1
    elif [[ ${#cmd_candidates[@]} -eq 1 ]]; then
        cmd_file="./${cmd_candidates[0]}"
    else
        if [[ "${FORCE_OVERWRITE}" == "1" ]]; then
            cmd_file="./${cmd_candidates[0]}"
            printf "Warning: Multiple executable .cmd files found. Auto-selecting '%s' due to --force.\n" "${cmd_file}"
        else
            printf "Multiple executable .cmd files found in %s:\n" "${abs_dir}"
            for ((i=0; i<${#cmd_candidates[@]}; i=$((i + 1)))); do
                printf "  [%d] %s\n" "$((i + 1))" "${cmd_candidates[$i]}"
            done

            while true; do
                printf "Select the startup script [1-%d]: " "${#cmd_candidates[@]}"
                if ! read -r selection; then
                    printf "\nError: Input stream closed (EOF). Aborting generation.\n" >&2
                    exit 1
                fi
                if [[ "${selection}" =~ ^[0-9]+$ ]] && [[ ${selection} -ge 1 && ${selection} -le ${#cmd_candidates[@]} ]]; then
                    cmd_file="./${cmd_candidates[$((selection - 1))]}"
                    break
                else
                    printf "Invalid selection. Please enter a number between 1 and %d.\n" "${#cmd_candidates[@]}"
                fi
            done
        fi
    fi

    if [[ "${EXEC_MODE}" == "system" ]]; then
        ioc_user="${TARGET_SYSTEM_USER}"
        ioc_group="${TARGET_SYSTEM_GROUP}"
        mode_flag=""
    else
        ioc_user=$(id -un)
        ioc_group=$(id -gn)
        mode_flag="--local "
    fi

    tmp_conf=$(mktemp "${TMPDIR:-/tmp}/ioc-runner-gen.XXXXXX.conf")
    trap 'rm -f "${tmp_conf:-}"' EXIT

    cat <<EOF > "${tmp_conf}"
IOC_NAME="${IOC_NAME}"
IOC_USER="${ioc_user}"
IOC_GROUP="${ioc_group}"
IOC_CHDIR="${abs_dir}"
IOC_PORT=""
IOC_CMD="${cmd_file}"
EOF

    if ! validate_conf "${tmp_conf}" validate_map; then
        rm -f "${tmp_conf}"
        exit 1
    fi

    # Compares the newly generated configuration with the existing one natively.
    # If identical, aborts the overwrite process gracefully to prevent unnecessary disk I/O and prompts.
    if [[ -f "${generated_conf}" ]]; then
        if cmp -s "${generated_conf}" "${tmp_conf}"; then
            print_divider
            printf "Info: Existing configuration '%s' is already up-to-date (Identical).\n" "${generated_conf}"
            printf "Skipping overwrite.\n"
            rm -f "${tmp_conf}"

            print_sub_divider
            cat "${generated_conf}"
            print_divider
            printf "Next step: %s install %s\n" "${0##*/}" "${generated_conf}"
            exit 0
        fi

        if [[ "${FORCE_OVERWRITE}" != "1" ]]; then
            print_divider
            printf "Configuration file '%s' already exists with differences.\n" "${generated_conf}"
            print_sub_divider
            if command -v diff >/dev/null 2>&1; then
                printf "  %b[-] Current Configuration : %s%b\n" "${RED}" "${generated_conf}" "${NC}"
                printf "  %b[+] Pending Configuration : (Auto-generated)%b\n" "${GREEN}" "${NC}"
                print_sub_divider

                # Executes a unified diff comparison, strips raw timestamp headers, and applies
                # ANSI color coding natively via Bash to visually distinguish current vs. pending states.
                while IFS= read -r line; do
                    if [[ "${line}" == ---* || "${line}" == +++* ]]; then
                        continue
                    elif [[ "${line}" == -* ]]; then
                        printf "%b%s%b\n" "${RED}" "${line}" "${NC}"
                    elif [[ "${line}" == +* ]]; then
                        printf "%b%s%b\n" "${GREEN}" "${line}" "${NC}"
                    elif [[ "${line}" == @@* ]]; then
                        printf "%b%s%b\n" "${BLUE}" "${line}" "${NC}"
                    else
                        printf "%s\n" "${line}"
                    fi
                done < <(diff -u "${generated_conf}" "${tmp_conf}" 2>/dev/null || true)
            else
                printf "Warning: diff utility not found. Cannot display changes.\n"
            fi
            print_divider
            printf "Do you want to overwrite it with the new configuration? [y/N]: "
            if ! read -r confirm; then
                printf "\nInfo: Input stream closed (EOF). Aborting generation.\n"
                rm -f "${tmp_conf}"
                exit 1
            fi
            # Issue #93: every abort exits nonzero; the requested action did
            # not happen, so a decline must not read as success to callers.
            if [[ ! "${confirm}" =~ ^[Yy]$ ]]; then
                printf "Generation aborted by user.\n"
                rm -f "${tmp_conf}"
                exit 1
            fi
        fi
    fi

    mv -f "${tmp_conf}" "${generated_conf}"
    trap - EXIT

    # Pre-allocate the EPICS shell history file. In system mode it is made
    # group-writable (0664) so the ioc-srv daemon can append via its 'ioc'
    # group membership; in --local mode it is owner-private (0600), matching
    # the single-principal local model.
    local hist_file="${abs_dir}/.iocsh_history"
    if [[ ! -f "${hist_file}" ]]; then
        touch "${hist_file}" 2>/dev/null || true
    fi
    if [[ "${EXEC_MODE}" == "system" ]]; then
        chmod 0664 "${hist_file}" 2>/dev/null || true
    else
        chmod 0600 "${hist_file}" 2>/dev/null || true
    fi

    print_divider
    printf "Configuration successfully generated and validated at: %s\n" "${generated_conf}"
    print_sub_divider
    cat "${generated_conf}"
    print_divider
    printf "Next step: %s %sinstall %s\n" "${0##*/}" "${mode_flag}" "${generated_conf}"
}

# Model-conformance check (PERMISSION_MODEL.md): IOC_CHDIR is an absolute
# 2775 tree -- group-owned by TARGET_SYSTEM_GROUP with setgid +
# group write+execute -- and every parent is traversable by the service
# account (other-execute, or TARGET_SYSTEM_GROUP with group-execute). No
# sudo, so root and an ioc-group operator agree. ACLs and symlinked paths
# are out of scope; IOC_CHDIR must be an absolute, non-symlinked path.
function chdir_conforms_to_system_model {
    local dir="$1"
    [[ "${dir}" == /* ]] || return 1            # absolute path required
    [[ ! -L "${dir}" ]] || return 1             # symlinked leaf out of scope
    [[ -d "${dir}" ]] || return 1
    local grp mode
    grp=$(stat -c '%G' "${dir}" 2>/dev/null) || return 1
    mode=$(stat -c '%a' "${dir}" 2>/dev/null) || return 1
    [[ "${grp}" == "${TARGET_SYSTEM_GROUP}" ]] || return 1
    (( (0${mode} & 02000) != 0 )) || return 1                            # setgid
    (( (0${mode} & 0020) != 0 && (0${mode} & 0010) != 0 )) || return 1   # group w + x
    local parent="${dir}"
    while [[ "${parent}" != "/" ]]; do
        parent=$(dirname "${parent}")
        [[ ! -L "${parent}" ]] || return 1      # symlinked parent out of scope
        local pgrp pmode
        pgrp=$(stat -c '%G' "${parent}" 2>/dev/null) || return 1
        pmode=$(stat -c '%a' "${parent}" 2>/dev/null) || return 1
        (( (0${pmode} & 0001) != 0 )) && continue                        # other-x
        [[ "${pgrp}" == "${TARGET_SYSTEM_GROUP}" ]] && (( (0${pmode} & 0010) != 0 )) && continue
        return 1
    done
    return 0
}

function do_install {
    local source_target="${TARGET_ARG}"
    local source_conf="${source_target}"
    local abs_dir=""
    local saved_pwd=""
    local resolved_ioc_name=""
    local -A install_conf=()

    # Resolves the target configuration file natively. If a directory is provided,
    # it locates the previously generated .conf file inside it to streamline the installation workflow.
    if [[ -d "${source_target}" ]]; then
        saved_pwd="${PWD}"
        cd "${source_target}" >/dev/null 2>&1 || exit 1
        abs_dir="${PWD}"
        cd "${saved_pwd}" >/dev/null 2>&1 || exit 1

        resolved_ioc_name="${abs_dir##*/}"
        source_conf="${abs_dir}/${resolved_ioc_name}.conf"

        if [[ ! -f "${source_conf}" ]]; then
            printf "Error: Configuration file '%s' not found in directory '%s'.\n" "${resolved_ioc_name}.conf" "${source_target}" >&2
            printf "Hint: Did you run '%s generate %s' first?\n" "${0##*/}" "${source_target}" >&2
            exit 1
        fi

        # Aligns the global IOC_NAME with the resolved directory base name and validates it.
        if [[ -z "${IOC_NAME}" || "${IOC_NAME}" == "${source_target}" || "${IOC_NAME}" == "." ]]; then
            IOC_NAME="${resolved_ioc_name}"
        fi
    elif [[ ! -f "${source_conf}" ]]; then
        printf "Error: Target '%s' is neither a valid directory nor a configuration file.\n" "${source_target}" >&2
        exit 1
    fi

    # Validate IOC_NAME at the convergence point so both directory and
    # file-direct invocations pass through the same regex guard before
    # any systemd unit name or filesystem path is constructed.
    validate_ioc_name "${IOC_NAME}" || exit 1

    if ! validate_conf "${source_conf}" install_conf; then
        exit 1
    fi

    # System-mode write-access precheck for IOC_CHDIR.
    # Verifies the directory conforms to the permission model so runtime
    # artifacts (iocsh history, autosave, save/restore state) do not fail
    # on startup. The model deploys system-mode IOCs under a 2775 tree
    # group-owned by ioc (typically root:ioc, e.g. /opt/epics-iocs/);
    # ioc-srv writes via TARGET_SYSTEM_GROUP
    # membership, so the check is by group ownership + mode, not sudo --
    # the result is identical for root and for an ioc-group operator.
    # FORCE_OVERWRITE bypasses the confirmation prompt but never suppresses
    # the warning emitted to stderr.
    if [[ "${EXEC_MODE}" == "system" ]]; then
        local chdir_target="${install_conf[IOC_CHDIR]:-}"
        local precheck_confirm

        # Reject a '..' path component outright. The conformance check below
        # walks parents lexically via dirname; a '..' makes that walk diverge
        # from the resolved physical path, so it would validate sibling
        # directories instead of the true parent chain. This is malformed
        # input, not a permission mismatch, so it aborts unconditionally
        # rather than flowing into the writability warning's y/N prompt.
        # Canonicalizing with realpath is avoided here because it would
        # resolve symlinks and weaken the per-segment symlink rejection.
        # A '..' component appears in exactly one of four positions: the whole
        # string, leading, interior, or trailing. These four globs cover all of
        # them so the rejection cannot be bypassed by a boundary-position '..'
        # (literal names like '..bar' are deliberately not matched).
        if [[ "${chdir_target}" == ".." || "${chdir_target}" == "../"* \
           || "${chdir_target}" == */../* || "${chdir_target}" == */.. ]]; then
            printf "Error: IOC_CHDIR '%s' contains a '..' component.\n" "${chdir_target}" >&2
            printf "       Provide a canonical absolute path without '..' so the system-model\n" >&2
            printf "       precheck validates the directory's true parent chain.\n" >&2
            exit 1
        fi

        if ! chdir_conforms_to_system_model "${chdir_target}"; then
            printf "Warning: IOC_CHDIR '%s' is not writable by '%s'.\n" "${chdir_target}" "${TARGET_SYSTEM_USER}" >&2
            printf "         System-mode IOCs should be deployed under /opt/epics-iocs/\n" >&2
            printf "         (or another 2775 tree group-owned by '%s' with setgid) so that %s can write\n" "${TARGET_SYSTEM_GROUP}" "${TARGET_SYSTEM_USER}" >&2
            printf "         runtime artifacts such as .iocsh_history and autosave files.\n" >&2
            printf "         Continuing will install the configuration, but the IOC may\n" >&2
            printf "         emit permission errors on startup that trigger crash detection\n" >&2
            printf "         false positives.\n" >&2
            printf "\n" >&2
            printf "         Hint: To silence only the .iocsh_history error, add\n" >&2
            printf "         epicsEnvSet(\"IOCSH_HISTSIZE\",\"0\") to st.cmd. This does not\n" >&2
            printf "         address autosave or save/restore write failures.\n" >&2
            if [[ "${FORCE_OVERWRITE}" != "1" ]]; then
                printf "         Proceed anyway? [y/N]: " >&2
                if ! read -r precheck_confirm; then
                    printf "\nInfo: Input stream closed (EOF). Aborting installation.\n" >&2
                    exit 1
                fi
                # Issue #93: abort exits nonzero (see the generate prompt).
                if [[ ! "${precheck_confirm}" =~ ^[Yy]$ ]]; then
                    printf "Installation aborted by user.\n"
                    exit 1
                fi
            fi
        fi
    fi

    local template_path="${SYSTEMD_DIR}/epics-@.service"

    if [[ "${EXEC_MODE}" == "system" ]]; then
        if [[ ! -f "${template_path}" ]]; then
            printf "Error: Systemd template %s not found.\n" "${template_path}" >&2
            printf "Please ensure the template is deployed by an administrator before installing IOCs.\n" >&2
            exit 1
        fi
    else
        # Ensure the resolved local log directory (LOG_DIR, which honors
        # IOC_RUNNER_LOG_DIR / IOC_RUNNER_LOCAL_LOG_DIR) exists before the
        # template is emitted, so the
        # rendered ExecStart= --logfile= path is valid on the first
        # systemctl --user start.
        install -d -m 0750 "${LOG_DIR}"
        deploy_local_template
    fi

    local state
    state=$(run_systemctl is-active "epics-@${IOC_NAME}.service" 2>/dev/null || true)

    # Block operation immediately if the service is not completely stopped
    if [[ "${state}" == "active" || "${state}" == "activating" || "${state}" == "deactivating" ]]; then
        print_divider >&2
        printf "Error: Operation aborted. Service '%s' is currently '%s'.\n" "${IOC_NAME}" "${state}" >&2
        printf "Please stop the service explicitly and wait for it to become inactive.\n" >&2
        print_divider >&2
        exit 1
    fi

    local original_port="${install_conf[IOC_PORT]:-}"

    local final_port
    final_port=$(process_ioc_port "${IOC_NAME}" "${original_port}") || exit 1

    if [[ ! -d "${CONF_DIR}" ]]; then
        if [[ "${EXEC_MODE}" == "system" ]]; then
            printf "Error: System configuration directory %s does not exist.\n" "${CONF_DIR}" >&2
            printf "Please ask an administrator to run setup-system-infra.bash.\n" >&2
            exit 1
        fi
        mkdir -p "${CONF_DIR}"
    elif [[ ! -w "${CONF_DIR}" ]]; then
        printf "Error: No write permission to %s. Are you in the '%s' group?\n" "${CONF_DIR}" "${TARGET_SYSTEM_GROUP}" >&2
        exit 1
    fi

    local target_conf="${CONF_DIR}/${IOC_NAME}.conf"

    if [[ -f "${target_conf}" ]]; then
        if [[ "${FORCE_OVERWRITE}" != "1" ]]; then
            printf "Warning: Configuration file '%s' already exists.\n" "${target_conf}"
            printf "Do you want to overwrite it? [y/N]: "
            if ! read -r confirm; then
                printf "\nInfo: Input stream closed (EOF). Aborting installation.\n"
                exit 1
            fi
            # Issue #93: abort exits nonzero (see the generate prompt).
            if [[ ! "${confirm}" =~ ^[Yy]$ ]]; then
                printf "Installation aborted by user.\n"
                exit 1
            fi
        else
            printf "Info: Overwriting existing configuration file '%s' (--force).\n" "${target_conf}"
        fi
    fi

    local tmp
    tmp=$(mktemp "${target_conf}.XXXXXX")
    trap 'rm -f "${tmp:-}"' EXIT
    grep -v '^[[:space:]]*IOC_PORT[[:space:]]*=' "${source_conf}" > "${tmp}"
    printf "IOC_PORT=\"%s\"\n" "${final_port}" >> "${tmp}"
    [[ "${EXEC_MODE}" == "system" ]] && chmod 0660 "${tmp}"
    mv -f "${tmp}" "${target_conf}"
    trap - EXIT

    run_systemctl daemon-reload

    printf "IOC %s installed in %s mode. Use 'start' command to run it.\n" "${IOC_NAME}" "${EXEC_MODE}"
}


function do_remove {
    if [[ -z "${IOC_NAME}" ]]; then
        printf "Error: Target IOC name is required for removal.\n" >&2
        exit 1
    fi

    local target_conf="${CONF_DIR}/${IOC_NAME}.conf"

    run_systemctl stop "epics-@${IOC_NAME}.service" 2>/dev/null || true
    run_systemctl disable "epics-@${IOC_NAME}.service" 2>/dev/null || true

    # Verify the service has actually stopped before deleting its configuration.
    local state
    state=$(run_systemctl is-active "epics-@${IOC_NAME}.service" 2>/dev/null || true)

    if [[ "${state}" == "active" || "${state}" == "activating" || "${state}" == "deactivating" ]]; then
        print_divider >&2
        printf "Error: Removal aborted. Service '%s' failed to stop cleanly (State: %s).\n" "${IOC_NAME}" "${state}" >&2
        printf "Please forcefully terminate the process before attempting removal to prevent systemd corruption.\n" >&2
        print_divider >&2
        exit 1
    fi

    rm -f "${target_conf}" || true

    # Clean up stale socket directory if systemd RuntimeDirectory cleanup was missed
    local sock_dir="${RUN_DIR}/${IOC_NAME}"
    if [[ -d "${sock_dir}" ]]; then
        rm -rf "${sock_dir}"
    fi

    run_systemctl daemon-reload
    printf "IOC %s removed.\n" "${IOC_NAME}"


}

function do_attach {

    resolve_con_tool
    resolve_sock_path

    print_divider >&2
    printf "Attaching to %s via %s:\n" "${IOC_NAME}" "${CON_TOOL_TYPE}"
    printf "Path: %s\n" "${RESOLVED_SOCK_PATH}"

    case "${CON_TOOL_TYPE}" in
        con)
            printf "Use Ctrl-A to exit the console.\n"
            print_divider >&2
            exec "${CON_TOOL_PATH}" -c "${RESOLVED_SOCK_PATH}" || exit
            ;;
        socat)
            printf "Use Ctrl-C to exit (Fallback tool).\n"
            print_divider >&2
            exec socat -,raw,echo=0 UNIX-CONNECT:"${RESOLVED_SOCK_PATH}" || exit
            ;;
        nc)
            printf "Use Ctrl-C to exit (Fallback tool).\n"
            print_divider >&2
            exec nc -U "${RESOLVED_SOCK_PATH}" || exit
            ;;
    esac
}


function do_monitor {

    resolve_con_tool
    resolve_sock_path

    print_divider >&2
    printf "Monitoring %s (Read-Only Mode) via %s:\n" "${IOC_NAME}" "${CON_TOOL_TYPE}"
    printf "Path: %s\n" "${RESOLVED_SOCK_PATH}"

    case "${CON_TOOL_TYPE}" in
        con)
            if "${CON_TOOL_PATH}" -h 2>&1 | grep -q "\-r"; then
                printf "Use Ctrl-A to exit.\n"
                print_divider >&2
                exec "${CON_TOOL_PATH}" -r -c "${RESOLVED_SOCK_PATH}" || exit
            else
                if command -v socat >/dev/null 2>&1; then
                    printf "Warning: 'con' does not support -r. Falling back to socat.\n" >&2
                    printf "Use Ctrl-C to exit.\n"
                    print_divider >&2
                    exec socat -u UNIX-CONNECT:"${RESOLVED_SOCK_PATH}" STDOUT || exit
                else
                    printf "Warning: 'con' does not support -r. Falling back to nc.\n" >&2
                    printf "Use Ctrl-C to exit.\n"
                    print_divider >&2
                    exec nc -U "${RESOLVED_SOCK_PATH}" < /dev/null || exit
                fi
            fi
            ;;
        socat)
            printf "Use Ctrl-C to exit.\n"
            print_divider >&2
            exec socat -u UNIX-CONNECT:"${RESOLVED_SOCK_PATH}" STDOUT || exit
            ;;
        nc)
            printf "Use Ctrl-C to exit.\n"
            print_divider >&2
            exec nc -U "${RESOLVED_SOCK_PATH}" < /dev/null || exit
            ;;
    esac
}

function do_list {
    if [[ ! -d "${RUN_DIR}" ]]; then
        printf "No active IOC sockets found in %s\n" "${RUN_DIR}"
        return 0
    fi

    local sockets=()
    local -A ioc_started_map=() ioc_perm_map=()
    local sock ts perm unit active rq sq path refcnt flags st inode key val b_id b_pid b_cpu b_mem i
    local entry hint_needed
    while IFS= read -r -d '' sock && IFS= read -r -d '' ts && IFS= read -r -d '' perm; do
        sockets+=("${sock}")
        ioc_started_map["${sock}"]="${ts}"
        ioc_perm_map["${sock}"]="${perm}"
    done < <(find "${RUN_DIR}" -type s -printf '%p\0%TY-%Tm-%Td %TH:%TM\0%M\0' 2>/dev/null || true)

    if [[ ${#sockets[@]} -eq 0 ]]; then
        printf "No active IOC sockets found in %s\n" "${RUN_DIR}"
        # Issue #94: the 0770 socket directories are not traversable by a
        # principal outside the ioc group, so an empty enumeration can mean
        # permission denial rather than no running IOCs. Hint only in that
        # case; a genuinely empty run dir keeps the original output.
        hint_needed=0
        if [[ ! -r "${RUN_DIR}" || ! -x "${RUN_DIR}" ]]; then
            hint_needed=1
        else
            for entry in "${RUN_DIR}"/*/; do
                if [[ -d "${entry}" && ( ! -r "${entry}" || ! -x "${entry}" ) ]]; then
                    hint_needed=1
                    break
                fi
            done
        fi
        if [[ ${hint_needed} -eq 1 ]]; then
            printf "(socket directories are not readable by this user; use systemctl status for service state)\n"
        fi
        return 0
    fi

    local systemctl_cmd=("${SYSTEMCTL_BIN}")
    if [[ "${EXEC_MODE}" == "local" ]]; then
        systemctl_cmd=("${SYSTEMCTL_BIN}" "--user")
    fi

    # --- Memory Optimization: Stream Parsing & O(1) Hash Maps ---
    local -A ioc_status_map=()
    local -A ioc_rq_map=() ioc_sq_map=()
    local -A ioc_pid_map=() ioc_cpu_map=() ioc_mem_map=()

    # 1. Map systemd states directly to memory
    while read -r unit _ active _ _; do
        if [[ "${unit}" =~ epics-@(.*)\.service ]]; then
            ioc_status_map["${BASH_REMATCH[1]}"]="${active}"
        fi
    done < <("${systemctl_cmd[@]}" list-units "epics-@*.service" --no-legend --plain 2>/dev/null || true)

    # 2. Map socket queue statistics using ss.
    # Command substitution propagates ss exit code to set -e; a missing or
    # broken ss aborts do_list rather than silently producing an empty map.
    local ss_lx_out
    ss_lx_out=$(ss -lx 2>/dev/null)
    while read -r _ _ rq sq path _; do
        if [[ "${path}" == "${RUN_DIR%/}/"* ]]; then
            ioc_rq_map["${path}"]="${rq}"
            ioc_sq_map["${path}"]="${sq}"
        fi
    done <<< "${ss_lx_out}"

    # 2-A. Map explicit kernel internal states from /proc/net/unix
    local -A ioc_ref_map=() ioc_state_map=() ioc_inode_map=()
    local is_listen
    # Fields: Num RefCount Protocol Flags Type St Inode Path
    {
        read -r _  # skip header
        while read -r _ refcnt _ flags _ st inode path; do
            if [[ "${path}" == "${RUN_DIR%/}/"* ]]; then
                # Convert hex flags to decimal and check the __SO_ACCEPTCON bit (0x10000)
                is_listen=$(( 16#${flags} & 16#00010000 ))

                if [[ ${is_listen} -ne 0 ]]; then
                    ioc_ref_map["${path}"]=$(( 16#${refcnt} ))
                    ioc_state_map["${path}"]="LISTEN"
                    ioc_inode_map["${path}"]="${inode}"
                elif [[ -z "${ioc_state_map[${path}]:-}" ]]; then
                    ioc_ref_map["${path}"]=$(( 16#${refcnt} ))
                    case "${st}" in
                        "01") ioc_state_map["${path}"]="UNCONN" ;;
                        "02") ioc_state_map["${path}"]="CONNECTING" ;;
                        "03") ioc_state_map["${path}"]="ESTAB" ;;
                        "04") ioc_state_map["${path}"]="DISCONN" ;;
                        *)    ioc_state_map["${path}"]="${st}" ;;
                    esac
                    ioc_inode_map["${path}"]="${inode}"
                fi
            fi
        done
    } < "/proc/net/unix"


    # 3. Pre-fetch verbose properties if -v or -vv is used
    if [[ ${VERBOSE_LEVEL} -ge 1 ]]; then
        b_id="" b_pid="" b_cpu="" b_mem=""

        while IFS='=' read -r key val || [[ -n "${key:-}" ]]; do
            if [[ -z "${key}" ]]; then
                # Empty line marks the end of a systemd unit block
                if [[ "${b_id}" =~ epics-@(.*)\.service ]]; then
                    i="${BASH_REMATCH[1]}"
                    ioc_pid_map["${i}"]="${b_pid}"
                    ioc_cpu_map["${i}"]="${b_cpu}"
                    ioc_mem_map["${i}"]="${b_mem}"
                fi
                b_id="" b_pid="" b_cpu="" b_mem=""
                continue
            fi

            case "${key}" in
                Id)            b_id="${val}" ;;
                MainPID)       b_pid="${val}" ;;
                CPUUsageNSec)  b_cpu="${val}" ;;
                MemoryCurrent) b_mem="${val}" ;;
            esac
        done < <("${systemctl_cmd[@]}" show "epics-@*.service" --property=Id,MainPID,CPUUsageNSec,MemoryCurrent 2>/dev/null || true)

        # Commit the final block in case there is no trailing empty line
        if [[ "${b_id}" =~ epics-@(.*)\.service ]]; then
            i="${BASH_REMATCH[1]}"
            ioc_pid_map["${i}"]="${b_pid}"
            ioc_cpu_map["${i}"]="${b_cpu}"
            ioc_mem_map["${i}"]="${b_mem}"
        fi
    fi

    if [[ ${VERBOSE_LEVEL} -eq 0 ]]; then
        printf "%-20s | %-8s | %-17s | %s\n" \
            "IOC NAME" "STATUS" "STARTED" "UDS PATH"
    elif [[ ${VERBOSE_LEVEL} -eq 1 ]]; then
        printf "%-20s | %-8s | %-17s | %-6s | %-5s | %-6s | %s\n" \
            "IOC NAME" "STATUS" "STARTED" "PID" "CPU" "MEM" "UDS PATH"
    else
        printf "%-20s | %-8s | %-17s | %-6s | %-5s | %-6s | %-3s | %-3s | %-4s | %-9s | %-10s | %-10s | %s\n" \
            "IOC NAME" "STATUS" "STARTED" "PID" "CPU" "MEM" "RQ" "SQ" "REF" "K-STATE" "INODE" "PERM" "UDS PATH"
    fi

    print_sub_divider

    local ioc_name status started
    local pid cpu mem recv_q send_q
    local cpu_ns mem_bytes cpu_dec mem_dec
    local ref_cnt k_state

    for sock in "${sockets[@]}"; do
        ioc_name="${sock%/*}"
        ioc_name="${ioc_name##*/}"

        status="${ioc_status_map[${ioc_name}]:-unknown}"
        started="${ioc_started_map[${sock}]:-N/A}"

        if [[ ${VERBOSE_LEVEL} -eq 0 ]]; then
            printf "%-20s | %-8s | %-17s | %s\n" \
                "${ioc_name}" "${status}" "${started}" "${sock}"

        elif [[ ${VERBOSE_LEVEL} -ge 1 ]]; then
            pid="${ioc_pid_map[${ioc_name}]:-N/A}"
            cpu_ns="${ioc_cpu_map[${ioc_name}]:-}"
            mem_bytes="${ioc_mem_map[${ioc_name}]:-}"

            if [[ "${pid}" == "0" ]]; then pid="N/A"; fi

            if [[ -n "${cpu_ns}" && "${cpu_ns}" != "18446744073709551615" && "${cpu_ns}" != "[not set]" ]]; then
                cpu_dec=$(( (cpu_ns + 50000000) / 100000000 ))
                cpu="$((cpu_dec / 10)).$((cpu_dec % 10))s"
            else
                cpu="N/A"
            fi

            if [[ -n "${mem_bytes}" && "${mem_bytes}" != "18446744073709551615" && "${mem_bytes}" != "[not set]" ]]; then
                mem_dec=$(( (mem_bytes * 10 + 524288) / 1048576 ))
                mem="$((mem_dec / 10)).$((mem_dec % 10))M"
            else
                mem="N/A"
            fi

            if [[ ${VERBOSE_LEVEL} -eq 1 ]]; then
                printf "%-20s | %-8s | %-17s | %-6s | %-5s | %-6s | %s\n" \
                    "${ioc_name}" "${status}" "${started}" \
                    "${pid}" "${cpu}" "${mem}" "${sock}"
            else
                recv_q="${ioc_rq_map[${sock}]:-0}"
                send_q="${ioc_sq_map[${sock}]:-0}"
                ref_cnt="${ioc_ref_map[${sock}]:-0}"
                k_state="${ioc_state_map[${sock}]:-UNKNOWN}"
                inode="${ioc_inode_map[${sock}]:-N/A}"
                perm="${ioc_perm_map[${sock}]:-N/A}"

                printf "%-20s | %-8s | %-17s | %-6s | %-5s | %-6s | %-3s | %-3s | %-4s | %-9s | %-10s | %-10s | %s\n" \
                    "${ioc_name}" "${status}" "${started}" \
                    "${pid}" "${cpu}" "${mem}" "${recv_q}" "${send_q}" \
                    "${ref_cnt}" "${k_state}" "${inode}" "${perm}" "${sock}"
            fi
        fi
    done
}


function do_view {
    if [[ -z "${IOC_NAME}" ]]; then
        printf "Error: Target IOC name is required to view.\n" >&2
        exit 1
    fi

    local target_conf="${CONF_DIR}/${IOC_NAME}.conf"

    print_divider
    printf "1. IOC Configuration File: %s\n" "${target_conf}"
    print_sub_divider
    if [[ -f "${target_conf}" ]]; then
        cat "${target_conf}"
    else
        printf "Error: Configuration file not found at %s\n" "${target_conf}" >&2
    fi
    printf "\n"

    print_divider
    printf "2. Systemd Template Unit\n"
    print_sub_divider
    run_systemctl cat "epics-@${IOC_NAME}.service" || true
    print_divider
}


function do_inspect {
    if [[ -z "${IOC_NAME}" ]]; then
        printf "Error: Target IOC name is required for inspect.\n" >&2
        exit 1
    fi

    # Enforce root privileges in system mode to ensure complete visibility of all client file descriptors.
    # Local mode allows execution as the standard user since they own both the socket and the client processes.
    if [[ "${EXEC_MODE}" == "system" && $EUID -ne 0 ]]; then
        printf "Error: 'inspect' requires root privileges in system mode to map client processes.\n" >&2
        printf "Hint: Execute with sudo.\n" >&2
        exit 1
    fi

    resolve_sock_path
    # Local alias for RESOLVED_SOCK_PATH, named for readability across this
    # command's long FD-mapping block below. do_attach/do_monitor have short
    # bodies and reference the global directly; the naming split is intentional.
    local sock_path="${RESOLVED_SOCK_PATH}"

    if ! command -v lsof >/dev/null 2>&1; then
        printf "Error: 'lsof' utility is required but not found in PATH.\n" >&2
        exit 1
    fi

    if ! command -v awk >/dev/null 2>&1; then
        printf "Error: 'awk' utility is required but not found in PATH.\n" >&2
        exit 1
    fi

    if ! command -v ss >/dev/null 2>&1; then
        printf "Error: 'ss' utility is required but not found in PATH.\n" >&2
        exit 1
    fi

    print_divider
    printf "Deep Inspection: %s\n" "${IOC_NAME}"
    printf "Target Socket: %s\n" "${sock_path}"
    print_sub_divider

    printf "1. UNIX Domain Socket FDs (lsof -U)\n"
    printf "   [Legend]\n"
    printf "   - FD          : File Descriptor (e.g., 'u' denotes read/write access)\n"
    printf "   - NODE        : Inode Number (Matches the INODE column in 'list -vv')\n"
    printf "   - (LISTEN)    : Server socket waiting for connections\n"
    printf "   - (CONNECTED) : Server-side socket for an accepted client session\n"
    print_sub_divider

    local lsof_found=0
    local -a server_pids=()
    local -A seen_server_pids=()
    local line pid c_pid

    # 1. Gather server PIDs via lsof, restricted to the target socket path.
    # The -a flag forces AND semantics across selection criteria; without it,
    # lsof defaults to OR and combining -U with a path argument dumps every
    # UNIX socket on the host (systemd, journal, D-Bus, etc.). With -a, the
    # listing narrows to UNIX sockets that match the target path, keeping
    # scan time under one second on typical systems. lsof only retains the
    # path for the server side of the connection, so client-side discovery
    # is handled by the Netlink peer-inode mapping in section 2 (ss -x -a -p).
    # Fallback: if the installed lsof does not support -a, drop both -a and
    # "${sock_path}" from the invocation and restore the bash-level filter
    # "elif [[ "${line}" == *"${sock_path}"* ]]". Section 2 covers client PIDs
    # independently via ss, so output completeness is preserved either way.
    while IFS= read -r line; do
        if [[ "${line}" == COMMAND* ]]; then
            printf "%s\n" "${line}"
        else
            printf "%s\n" "${line}"
            read -r _ pid _ <<< "${line}"
            if [[ -z "${seen_server_pids[${pid}]:-}" ]]; then
                server_pids+=("${pid}")
                seen_server_pids["${pid}"]=1
            fi
            lsof_found=1
        fi
    done < <(lsof -a -U -- "${sock_path}" 2>/dev/null || true)

    if [[ ${lsof_found} -eq 0 ]]; then
        printf "No active UNIX sockets detected for this path.\n"
    fi
    printf "\n"

    # 2. Trace true client PIDs via Netlink peer inode mapping (ss -x -a -p).
    # A single awk pass replaces the former per-line bash loop. On a host
    # with many unrelated UDS sockets the bash loop walked every ss output
    # line (O(lines)) and dominated inspect runtime; awk performs the same
    # peer-inode and inode->PID mapping in one pass. pid= is matched against
    # the whole line because the process field can contain spaces (e.g.
    # "Isolated Web Co"), which would split a field-indexed match. awk emits
    # client-candidate PIDs; the server-PID exclusion and dedup below
    # preserve the original bash policy.
    local -a client_pids=()
    local -A seen_client_pids=()
    local ss_peer_out
    if ! ss_peer_out=$(ss -x -a -p 2>/dev/null); then
        printf "Error: 'ss -x -a -p' failed; cannot trace client connections.\n" >&2
        exit 1
    fi
    while read -r c_pid; do
        [[ -n "${c_pid}" ]] || continue
        if [[ -z "${seen_server_pids[${c_pid}]:-}" && -z "${seen_client_pids[${c_pid}]:-}" ]]; then
            client_pids+=("${c_pid}")
            seen_client_pids["${c_pid}"]=1
        fi
    done < <(printf '%s\n' "${ss_peer_out}" | awk -v sock="${sock_path}" '
        $2 == "ESTAB" {
            if ($5 == sock) target_peer[$8] = 1
            if (match($0, /pid=[0-9]+/)) inode_pid[$6] = substr($0, RSTART + 4, RLENGTH - 4)
        }
        END { for (p in target_peer) if (p in inode_pid) print inode_pid[p] }
    ')

    print_divider
    printf "2. Server Process Context (procServ & IOC)\n"
    printf "   [Description]\n"
    printf "   - Displays the active daemon and its spawned payload processes.\n"
    print_sub_divider
    if [[ ${#server_pids[@]} -gt 0 ]]; then
        # Use a subshell to temporarily alter IFS for comma-separated PID formatting
        (
            IFS=","
            ps -o pid,user,tty,stat,lstart,cmd -p "${server_pids[*]}"
        )
    else
        printf "No server processes found. The socket might be orphaned.\n"
    fi
    printf "\n"

    print_divider
    printf "3. Client Process Context (Active Connections)\n"
    printf "   [Description]\n"
    printf "   - Traced via Netlink peer inode mapping.\n"
    printf "   - Displays external processes currently attached to the socket.\n"
    print_sub_divider
    if [[ ${#client_pids[@]} -gt 0 ]]; then
        (
            IFS=","
            ps -o pid,user,tty,stat,lstart,cmd -p "${client_pids[*]}"
        )
    else
        printf "No external client connections detected.\n"
    fi
    print_divider

}

function do_start_restart {
    local action="$1"

    if [[ -z "${IOC_NAME}" ]]; then
        printf "Error: Target IOC name is required for %s.\n" "${action}" >&2
        exit 1
    fi

    # Refresh systemd template cache for NFS environments lacking inotify support
    if [[ "${EXEC_MODE}" == "local" ]]; then
        run_systemctl daemon-reload
    fi

    local log_file="${LOG_DIR}/${IOC_NAME}.log"
    local log_start_offset log_start_inode log_start_tailhash
    log_start_offset=$(get_file_size "${log_file}")
    log_start_inode=$(get_file_inode "${log_file}")
    log_start_tailhash=$(get_file_tailhash "${log_file}" "${log_start_offset}")

    run_systemctl "${action}" "epics-@${IOC_NAME}.service"


    # Allow time for device connection timeouts
    sleep 5

    local post_state
    post_state=$(run_systemctl is-active "epics-@${IOC_NAME}.service" 2>/dev/null || true)

    if [[ "${post_state}" != "active" ]]; then
        printf "\nError: IOC '%s' failed to start or crashed immediately (State: %s).\n" "${IOC_NAME}" "${post_state}" >&2
        printf "  -> Troubleshooting: Check the logs by running the following command:\n" >&2
        print_log_file_hint "${log_file}"
        exit 1
    fi

    # Issue #25: append per-IOC CRASH_LOG_PATTERNS_EXTRA when present.
    local target_conf="${CONF_DIR}/${IOC_NAME}.conf"
    local extra_patterns=""
    if [[ -f "${target_conf}" ]]; then
        extra_patterns=$(read_conf_var "${target_conf}" "CRASH_LOG_PATTERNS_EXTRA" 2>/dev/null || printf "")
    fi
    local effective_patterns="${CRASH_LOG_PATTERNS}"
    if [[ -n "${extra_patterns}" ]]; then
        effective_patterns="${CRASH_LOG_PATTERNS}|${extra_patterns}"
    fi

    local scan_status=0
    if scan_file_for_crash_patterns "${log_file}" "${log_start_offset}" "${log_start_inode}" "${log_start_tailhash}" "${effective_patterns}"; then
        scan_status=0
    else
        scan_status=$?
    fi

    if [[ ${scan_status} -eq 0 ]]; then
        printf "\nWarning: IOC '%s' is active, but procServ may be crash-looping or reporting fatal errors.\n" "${IOC_NAME}" >&2
        print_log_file_hint "${log_file}"
    elif [[ ${scan_status} -eq 2 ]]; then
        printf "\nWarning: IOC '%s' is active, but startup logs could not be scanned.\n" "${IOC_NAME}" >&2
        print_log_file_hint "${log_file}"
    else
        printf "IOC '%s' successfully started.\n" "${IOC_NAME}"
    fi
}

case "${COMMAND_ACTION}" in
    generate)
        do_generate
        ;;
    install)
        do_install
        ;;
    remove)
        do_remove
        ;;
    attach)
        do_attach
        ;;
    monitor)
        do_monitor
        ;;
    list)
        do_list
        ;;
    inspect)
        do_inspect
        ;;
    view)
        do_view
        ;;
    stop|status|enable|disable)
        if [[ -z "${IOC_NAME}" ]]; then
            printf "Error: Target IOC name is required for %s.\n" "${COMMAND_ACTION}" >&2
            exit 1
        fi
        run_systemctl "${COMMAND_ACTION}" "epics-@${IOC_NAME}.service"
        ;;
    start|restart)
        do_start_restart "${COMMAND_ACTION}"
        ;;
    *)
        print_usage
        exit 1
        ;;
esac
