#!/usr/bin/env bash
#
# A front-end CLI manager for EPICS IOCs.
# Utilizes systemd template units (@.service) for zero-dependency management.
# Supports both system-wide deployment and local user-level testing.

set -e

# --- Configuration Directories ---
declare -g SYSTEM_CONF_DIR="${IOC_RUNNER_CONF_DIR:-/etc/procServ.d}"
declare -g LOCAL_CONF_DIR="${IOC_RUNNER_CONF_DIR:-${HOME}/.config/procServ.d}"
declare -g SYSTEM_SYSTEMD_DIR="${IOC_RUNNER_SYSTEMD_DIR:-/etc/systemd/system}"
declare -g LOCAL_SYSTEMD_DIR="${IOC_RUNNER_SYSTEMD_DIR:-${HOME}/.config/systemd/user}"
declare -g SYSTEM_RUN_DIR="${IOC_RUNNER_RUN_DIR:-/run/procserv}"
declare -g LOCAL_RUN_DIR="${IOC_RUNNER_RUN_DIR:-/run/user/$(id -u)/procserv}"

# --- Base Commands & Paths ---
declare -g SYSTEMCTL_BIN="/bin/systemctl"
declare -g -a CON_SEARCH_PATHS=("/usr/local/bin/con" "/usr/bin/con")
declare -g -a PROCSERV_SEARCH_PATHS=("/usr/local/bin/procServ" "/usr/bin/procServ")

# --- Active State Variables ---
declare -g EXEC_MODE="system"
declare -g CONF_DIR="${SYSTEM_CONF_DIR}"
declare -g SYSTEMD_DIR="${SYSTEM_SYSTEMD_DIR}"
declare -g RUN_DIR="${SYSTEM_RUN_DIR}"
declare -g CON_TOOL=""


function print_divider {
    printf "%s\n" "===================================================================================================="
}

function print_sub_divider {
    printf "%s\n" "----------------------------------------------------------------------------------------------------"
}

function set_local_mode {
    EXEC_MODE="local"
    CONF_DIR="${LOCAL_CONF_DIR}"
    SYSTEMD_DIR="${LOCAL_SYSTEMD_DIR}"
    RUN_DIR="${LOCAL_RUN_DIR}"
}

function print_usage {
    local prog_name
    prog_name=$(basename "$0")

    cat << EOF
EPICS IOC Runner - CLI Manager

Usage: ${prog_name} [OPTIONS] COMMAND [TARGET]

Options:
  --local        Run in local user mode (no sudo required, uses ~/.config/procServ.d)
  -h, --help     Show this help message and exit

Commands:
  install        Install a new IOC configuration file (.conf) and reload systemd
  remove         Stop, disable, and remove an existing IOC configuration
  start          Start the specified IOC service
  stop           Stop the specified IOC service
  restart        Restart the specified IOC service
  status         Show the systemd status of the IOC service
  enable         Enable the IOC service to start on boot
  disable        Disable the IOC service from starting on boot
  view           Print the contents of the generated systemd unit file
  list           List all active UNIX Domain Sockets for managed IOCs (no target required)
  attach         Attach to the IOC console via UNIX Domain Socket (use Ctrl-A to detach)

Examples:
  ${prog_name} install myioc.conf      # Install system-wide IOC
  ${prog_name} start myioc             # Start the system-wide IOC
  ${prog_name} attach myioc            # Connect to the IOC console
  ${prog_name} --local install t.conf  # Install IOC in local user space
EOF
}


if [[ "$1" == "--local" ]]; then
    set_local_mode
    shift
fi

if [[ $# -lt 1 || "$1" == "-h" || "$1" == "--help" ]]; then
    print_usage
    exit 0
fi

declare -g COMMAND_ACTION="$1"
shift

declare -g TARGET_ARG="$1"
declare -g IOC_NAME=""

if [[ -n "${TARGET_ARG}" ]]; then
    IOC_NAME=$(basename "${TARGET_ARG}" .conf)
fi

# Reject IOC names containing characters outside the allowed set.
if [[ -n "${IOC_NAME}" && ! "${IOC_NAME}" =~ ^[a-zA-Z0-9_-]+$ ]]; then
    printf "Error: Invalid IOC name '%s'. Only alphanumeric characters, '-', and '_' are allowed.\n" "${IOC_NAME}" >&2
    exit 1
fi

function run_systemctl {
    local action="$1"
    shift

    if [[ "${EXEC_MODE}" == "local" ]]; then
        "${SYSTEMCTL_BIN}" --user "${action}" "$@"
    else
        case "${action}" in
            is-active|status|cat|show)
                "${SYSTEMCTL_BIN}" "${action}" "$@"
                ;;
            *)
                if [[ $EUID -eq 0 ]]; then
                    "${SYSTEMCTL_BIN}" "${action}" "$@"
                else
                    sudo "${SYSTEMCTL_BIN}" "${action}" "$@"
                fi
                ;;
        esac
    fi
}

function deploy_local_template {
    local procserv_bin=""
    local template_path="${SYSTEMD_DIR}/epics-@.service"

    # Resolve procServ binary path
    for path in "${PROCSERV_SEARCH_PATHS[@]}"; do
        if [[ -x "${path}" ]]; then
            procserv_bin="${path}"
            break
        fi
    done

    if [[ -z "${procserv_bin}" ]]; then
        printf "%s\n" "Error: procServ executable not found in standard paths." >&2
        exit 1
    fi

    if [[ ! -f "${template_path}" ]]; then
        printf "Deploying user-level systemd template to %s...\n" "${template_path}"
        mkdir -p "${SYSTEMD_DIR}"
        cat > "${template_path}" <<EOF
[Unit]
Description=procServ for %i (Local User)
AssertFileNotEmpty=${CONF_DIR}/%i.conf

[Service]
Type=simple
EnvironmentFile=${CONF_DIR}/%i.conf
RuntimeDirectory=procserv/%i
ExecStart=${procserv_bin} --foreground --logfile=- --name=%i --ignore=^D^C^] --chdir=\${IOC_CHDIR} --port=\${IOC_PORT} \${IOC_CMD}
StandardOutput=syslog
StandardError=inherit
SyslogIdentifier=epics-%i

[Install]
WantedBy=default.target
EOF
        run_systemctl daemon-reload
    fi
}

function do_install {
    local source_conf="${TARGET_ARG}"
    if [[ ! -f "${source_conf}" ]]; then
        printf "Error: Configuration file %s not found.\n" "${source_conf}" >&2
        exit 1
    fi

    local template_path="${SYSTEMD_DIR}/epics-@.service"

    if [[ "${EXEC_MODE}" == "system" ]]; then
        if [[ ! -f "${template_path}" ]]; then
            printf "Error: Systemd template %s not found.\n" "${template_path}" >&2
            printf "Please ensure the template is deployed by an administrator before installing IOCs.\n" >&2
            exit 1
        fi
    else
        deploy_local_template
    fi

    local state
    state=$(run_systemctl is-active "epics-@${IOC_NAME}.service" 2>/dev/null || true)

    if [[ "${state}" == "active" ]]; then
        print_divider >&2
        printf "WARNING: Installation aborted.\n" >&2
        printf "IOC '%s' is currently running.\n" "${IOC_NAME}" >&2
        printf "Please stop the service explicitly before reinstalling to prevent data loss.\n" >&2
        print_divider >&2
        exit 1
    fi

    if [[ ! -d "${CONF_DIR}" ]]; then
        if [[ "${EXEC_MODE}" == "system" && $EUID -ne 0 ]]; then
            sudo mkdir -p "${CONF_DIR}"
        else
            mkdir -p "${CONF_DIR}"
        fi
    fi

    if [[ "${EXEC_MODE}" == "system" && ! -w "${CONF_DIR}" ]]; then
        sudo cp "${source_conf}" "${CONF_DIR}/"
    else
        cp "${source_conf}" "${CONF_DIR}/"
    fi

    run_systemctl daemon-reload

    printf "IOC %s installed in %s mode. Use 'start' command to run it.\n" "${IOC_NAME}" "${EXEC_MODE}"
}

function do_remove {
    if [[ -z "${IOC_NAME}" ]]; then
        printf "Error: Target IOC name is required for removal.\n" >&2
        exit 1
    fi

    local target_conf="${CONF_DIR}/${IOC_NAME}.conf"

    run_systemctl stop "epics-@${IOC_NAME}.service" 2>/dev/null || true
    run_systemctl disable "epics-@${IOC_NAME}.service" 2>/dev/null || true

    if [[ "${EXEC_MODE}" == "system" && ! -w "${CONF_DIR}" ]]; then
        sudo rm -f "${target_conf}" || true
    else
        rm -f "${target_conf}" || true
    fi

    run_systemctl daemon-reload
    printf "IOC %s removed.\n" "${IOC_NAME}"
}

function do_attach {

    local con_tool="${IOC_RUNNER_CON_TOOL:-}"
    if [[ -z "${con_tool}" ]]; then
        for path in "${CON_SEARCH_PATHS[@]}"; do
            if [[ -x "${path}" ]]; then
                con_tool="${path}"
                break
            fi
        done
    fi

    if [[ -z "${con_tool}" ]]; then
        printf "%s\n" "Error: con utility not found in standard paths." >&2
        printf "%s\n" "Please install con before managing EPICS IOCs." >&2
        exit 1
    fi

    if [[ -z "${IOC_NAME}" ]]; then
        printf "Error: Target IOC name is required to attach.\n" >&2
        exit 1
    fi

    local target_conf="${CONF_DIR}/${IOC_NAME}.conf"

    if [[ ! -f "${target_conf}" ]]; then
        printf "Error: Configuration for %s not found.\n" "${IOC_NAME}" >&2
        exit 1
    fi

    local sock_path
    sock_path=$(grep -E '^IOC_PORT=' "${target_conf}" | cut -d'=' -f2- | tr -d '"' | awk -F: '{print $NF}')


    print_divider >&2
    printf "Attaching to %s via UNIX domain socket:\n" "${IOC_NAME}"
    printf "Path: %s\n" "${sock_path}"
    printf "Use Ctrl-A to exit the console.\n"
    print_divider >&2

    exec "${con_tool}" -c "${sock_path}" || exit
}

function do_list {
    if [[ ! -d "${RUN_DIR}" ]]; then
        printf "No active IOC sockets found in %s\n" "${RUN_DIR}"
        return 0
    fi

    local sockets=()
    while IFS= read -r -d '' sock; do
        sockets+=("$sock")
    done < <(find "${RUN_DIR}" -type s -print0 2>/dev/null)

    if [[ ${#sockets[@]} -eq 0 ]]; then
        printf "No active IOC sockets found in %s\n" "${RUN_DIR}"
        return 0
    fi

    print_divider
    printf "%-30s | %s\n" "IOC NAME" "UDS PATH"
    print_sub_divider

    local sock ioc_name
    for sock in "${sockets[@]}"; do
        ioc_name=$(basename "$(dirname "${sock}")")
        printf "%-30s | %s\n" "${ioc_name}" "${sock}"
    done
    print_divider
}

function do_view {
    if [[ -z "${IOC_NAME}" ]]; then
        printf "Error: Target IOC name is required to view.\n" >&2
        exit 1
    fi

    local target_conf="${CONF_DIR}/${IOC_NAME}.conf"

    print_divider
    printf "1. IOC Configuration File: %s\n" "${target_conf}"
    print_sub_divider
    if [[ -f "${target_conf}" ]]; then
        cat "${target_conf}"
    else
        printf "Error: Configuration file not found at %s\n" "${target_conf}" >&2
    fi
    printf "\n"

    print_divider
    printf "2. Systemd Template Unit\n"
    print_sub_divider
    run_systemctl cat "epics-@${IOC_NAME}.service" || true
    print_divider
}


case "${COMMAND_ACTION}" in
    install)
        do_install
        ;;
    remove)
        do_remove
        ;;
    attach)
        do_attach
        ;;
    list)
        do_list
        ;;
    view)
        do_view
        ;;
    start|stop|restart|status|enable|disable)
        if [[ -z "${IOC_NAME}" ]]; then
            printf "Error: Target IOC name is required for %s.\n" "${COMMAND_ACTION}" >&2
            exit 1
        fi
        run_systemctl "${COMMAND_ACTION}" "epics-@${IOC_NAME}.service"
        ;;
    *)
        print_usage
        exit 1
        ;;
esac
